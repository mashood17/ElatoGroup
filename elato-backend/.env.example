# Documents every environment variable the backend needs — never commit real values.
ENV=development
PORT=8000

# Generate fresh — do not reuse Supabase's own JWT secret.
JWT_SECRET=

# From the Supabase project dashboard (Settings -> API). SUPABASE_SECRET_KEY
# is the service-role key — server-only, must never reach a frontend build.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

WHATSAPP_BUSINESS_NUMBER=+919731400313

# Comma-separated, no trailing slash.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Admin panel origin — used to build password-reset links.
FRONTEND_ADMIN_URL=http://localhost:5174

# Optional — reviews/Instagram sync is stubbed (returns empty, changes
# nothing in Supabase) until these are set.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Instagram Graph API credentials (Meta for Developers), used only by
# app/services/instagram_service.py to sync Reels into Supabase — the
# frontend never sees these and never calls Instagram directly.
#
# INSTAGRAM_GRAPH_TOKEN: a long-lived Page access token for the Facebook
#   Page linked to the Instagram Business/Creator account, with the
#   instagram_basic + instagram_manage_insights permissions granted in
#   Meta for Developers > your app > Instagram Graph API. Short-lived
#   tokens expire in ~1 hour; exchange for a long-lived token (~60 days)
#   via GET /oauth/access_token?grant_type=fb_exchange_token, and re-issue
#   before it expires (Graph API has no refresh-token flow).
# INSTAGRAM_BUSINESS_ID: the Instagram Business Account's numeric user id —
#   GET /{page-id}?fields=instagram_business_account with the token above.
INSTAGRAM_GRAPH_TOKEN=
INSTAGRAM_BUSINESS_ID=

# Shared secret required in the X-Cron-Secret header to trigger sync jobs
# (POST /api/v1/sync/instagram, /api/v1/sync/reviews). Generate a random
# value, set it here, and also set it as the SYNC_CRON_SECRET repository
# secret in GitHub (Settings > Secrets and variables > Actions) — the
# .github/workflows/instagram-sync.yml scheduled workflow sends it in the
# X-Cron-Secret header every 30 minutes. That workflow also needs a
# BACKEND_SYNC_URL repository secret pointing at this backend's deployed
# sync endpoint, e.g. https://<your-render-service>.onrender.com/api/v1/sync/instagram.
SYNC_CRON_SECRET=

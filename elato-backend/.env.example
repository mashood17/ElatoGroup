# Documents every environment variable the backend needs — never commit real values.
ENV=development
PORT=8000

# Generate fresh — do not reuse Supabase's own JWT secret.
JWT_SECRET=

# From the Supabase project dashboard (Settings -> API). SUPABASE_SECRET_KEY
# is the service-role key — server-only, must never reach a frontend build.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

WHATSAPP_BUSINESS_NUMBER=+919731400313

# Comma-separated, no trailing slash.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
